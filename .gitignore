# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Prebuild / native projects (generated from app.json + config plugins)
android/
ios/

# Odoo module build artifacts
odoo_module/*.zip

# Python bytecode inside odoo modules
**/__pycache__/
*.pyc

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env
.env*.local

# typescript
*.tsbuildinfo

# Runtime / test artifacts (Claude session)
*.log
fake_prints/
appium-artifacts/
tablet*.png
tablet-*.png
ui-current.xml
*.apk
__pycache__/
*.pyc
**/kotprintimage/**/*.png
docs/.~lock*#

# more noise
.claude/
logcat*.txt
