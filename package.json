{
  "name": "nexgenn-restaurant",
  "version": "2.0.1",
  "main": "node_modules/expo/AppEntry.js",
  "type": "commonjs",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "generate-app-json": "node generateAppJson.js",
    "apk:debug": "cd android && .\\gradlew.bat assembleDebug",
    "apk:release": "cd android && .\\gradlew.bat assembleRelease",
    "logcat": "adb logcat -s ReactNativeJS:V ReactNative:V *:E",
    "detox:build": "detox build -c android.attached.debug",
    "detox:test": "detox test -c android.attached.debug",
    "detox:build:emu": "detox build -c android.emu.debug",
    "detox:test:emu": "detox test -c android.emu.debug",
    "appium:server": "appium",
    "appium:test": "wdio run wdio.conf.js",
    "appium:test:deep": "wdio run wdio.conf.js --suite deep",
    "appium:test:full": "wdio run wdio.conf.js --suite full",
    "verify:orders": "python tools/verify_apk_orders.py",
    "verify:module": "python tools/check_idempotency_module.py"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
