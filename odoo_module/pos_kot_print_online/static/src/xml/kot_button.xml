<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pos_kot_print.ControlButtons" t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('control-buttons')]" position="inside">
            <button class="btn btn-lg btn-warning py-5 flex-fill" t-on-click="onClickKotPrint">
                <i class="fa fa-cutlery me-2"/>KOT
            </button>
        </xpath>
    </t>
</templates>
