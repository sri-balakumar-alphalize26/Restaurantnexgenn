<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- KOT Printer: list view -->
    <record id="view_pos_kot_printer_list" model="ir.ui.view">
        <field name="name">pos.kot.printer.list</field>
        <field name="model">pos.kot.printer</field>
        <field name="arch" type="xml">
            <list string="KOT Setup" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name" placeholder="e.g. Pizza Station"/>
                <field name="config_id" string="POS"/>
                <field name="printer_type" string="Type"/>
                <field name="printer_ip" placeholder="192.168.1.20"/>
                <field name="printer_port" placeholder="9100"/>
                <field name="is_all_in_one" string="All in One KOT"/>
                <field name="category_ids" widget="many2many_tags" placeholder="Select categories..."/>
                <field name="connection_status" string="Status"
                       decoration-success="connection_status == 'online'"
                       decoration-danger="connection_status == 'offline'"
                       decoration-info="connection_status == 'agent'"
                       decoration-muted="connection_status == 'unknown'"
                       widget="badge"/>
                <button name="action_test_connection" type="object"
                        string="Test" icon="fa-plug" class="btn-link"/>
            </list>
        </field>
    </record>

    <!-- KOT Printer: form view -->
    <record id="view_pos_kot_printer_form" model="ir.ui.view">
        <field name="name">pos.kot.printer.form</field>
        <field name="model">pos.kot.printer</field>
        <field name="arch" type="xml">
            <form string="KOT Printer">
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection" icon="fa-plug" class="btn-primary"/>
                    <field name="connection_status" widget="statusbar"
                           statusbar_visible="unknown,online,offline,agent"/>
                </header>
                <sheet>
                    <group>
                        <group string="Printer Info">
                            <field name="name" placeholder="e.g. Pizza Station"/>
                            <field name="printer_ip" placeholder="192.168.1.20"/>
                            <field name="printer_port" placeholder="9100"/>
                        </group>
                        <group string="Routing">
                            <field name="config_id" string="POS Config"/>
                            <field name="printer_type" string="Type"/>
                            <field name="is_all_in_one" string="All in One KOT"
                                   invisible="printer_type != 'kot'"/>
                            <field name="category_ids" widget="many2many_tags"
                                   invisible="printer_type != 'kot' or is_all_in_one"
                                   placeholder="Select POS categories..."/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_pos_kot_printer" model="ir.actions.act_window">
        <field name="name">KOT Setup</field>
        <field name="res_model">pos.kot.printer</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No KOT printers configured yet.
            </p>
        </field>
    </record>

    <!-- Menu under POS > Configuration -->
    <menuitem
        id="menu_pos_kot_printer"
        name="KOT Setup"
        parent="point_of_sale.menu_point_config_product"
        action="action_pos_kot_printer"
        sequence="50"/>

    <!-- KOT Queue: list view -->
    <record id="view_pos_kot_queue_list" model="ir.ui.view">
        <field name="name">pos.kot.queue.list</field>
        <field name="model">pos.kot.queue</field>
        <field name="arch" type="xml">
            <list string="KOT Print Queue">
                <field name="create_date" string="Created"/>
                <field name="config_id"/>
                <field name="printer_ip"/>
                <field name="printer_port"/>
                <field name="state"
                       decoration-success="state=='done'"
                       decoration-danger="state=='failed'"
                       decoration-info="state=='pending'"
                       widget="badge"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <!-- KOT Queue Action + Menu -->
    <record id="action_pos_kot_queue" model="ir.actions.act_window">
        <field name="name">KOT Print Queue</field>
        <field name="res_model">pos.kot.queue</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem
        id="menu_pos_kot_queue"
        name="KOT Queue"
        parent="point_of_sale.menu_point_config_product"
        action="action_pos_kot_queue"
        sequence="51"/>

    <!-- Inline in POS Config form -->
    <record id="pos_config_view_form_kot" model="ir.ui.view">
        <field name="name">pos.config.form.kot</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="KOT Printers">
                    <field name="kot_use_queue" string="Online Mode (Queue for Print Agent)"/>
                    <field name="kot_category_printer_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="name" placeholder="e.g. Pizza Station"/>
                            <field name="printer_type" string="Type"/>
                            <field name="printer_ip" placeholder="192.168.1.20"/>
                            <field name="printer_port" placeholder="9100"/>
                            <field name="is_all_in_one" string="All in One KOT"/>
                            <field name="category_ids" widget="many2many_tags" placeholder="Select categories..."/>
                            <field name="connection_status" string="Status"
                                   decoration-success="connection_status == 'online'"
                                   decoration-danger="connection_status == 'offline'"
                                   decoration-info="connection_status == 'agent'"
                                   decoration-muted="connection_status == 'unknown'"
                                   widget="badge"/>
                            <button name="action_test_connection" type="object"
                                    string="Test" icon="fa-plug" class="btn-link"/>
                        </list>
                    </field>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
